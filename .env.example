# Server
PORT=3002

# Supabase (required for cloud database)
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for Google sign-in in the browser (publishable or anon key)
SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Live gold/silver USD spot (optional)
# Default provider — free, no API key:
METAL_PRICE_PROVIDER=gold-api
# GoldAPI.io (requires key):
# METAL_PRICE_PROVIDER=goldapi
# METAL_PRICE_API_KEY=your-goldapi-key
# Metals-API.com (requires key):
# METAL_PRICE_PROVIDER=metals-api
# METAL_PRICE_API_KEY=your-metals-api-key
