# Server
PORT=3002

# Required in production (Vercel/Lambda). Local JSON files are not writable in serverless.
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Or use the new secret key name from Supabase Dashboard:
# SUPABASE_SECRET_KEY=sb_secret_...

# Required for sign-in in the browser (publishable or anon key)
SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Optional: run npm run apply:migration (Dashboard → Settings → Database → URI)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Public URL for password-reset email links (production)
# APP_URL=https://your-app.vercel.app

# Server cron: auto-fetch live gold price → Supabase (save only when price changes)
# Vercel Cron calls /api/cron/capture-gold-rate every minute when CRON_SECRET is set.
# Generate: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret
# Optional currency for cron capture (USD or CAD)
# CRON_METAL_CURRENCY=USD

# Live gold/silver spot prices (Vercel: add in Project → Settings → Environment Variables)
# Free provider — no API key required (recommended for production):
METAL_PRICE_PROVIDER=gold-api
# GoldAPI.io (requires key):
# METAL_PRICE_PROVIDER=goldapi
# METAL_PRICE_API_KEY=your-goldapi-key
# Metals-API.com (requires key):
# METAL_PRICE_PROVIDER=metals-api
# METAL_PRICE_API_KEY=your-metals-api-key
